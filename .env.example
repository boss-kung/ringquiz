# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.

# Supabase project URL — found in: Supabase dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key — found in: Supabase dashboard → Settings → API
# This key is safe to include in the browser bundle. RLS protects the data.
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# (Optional) Override the Edge Function base URL.
# Useful when running supabase locally: http://127.0.0.1:54321/functions/v1
# Leave blank to derive from VITE_SUPABASE_URL (default for production).
VITE_FUNCTIONS_URL=

# ──────────────────────────────────────────────────────────────
# HOST_SECRET is NOT stored here.
# It is set as a Supabase Edge Function secret:
#   supabase secrets set HOST_SECRET=<32-char-random>
# The host enters this value manually in the host panel UI.
# It is stored in sessionStorage only (cleared on tab close).
# ──────────────────────────────────────────────────────────────
